<div class="mb-8">
  <h1 class="text-xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">Topic Research</h1>
  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">Search for videos and find outliers</p>
</div>

<div class="mb-8 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-5">
  <%= form_with url: search_path, method: :get, class: "space-y-4" do |f| %>
    <div class="flex gap-3">
      <%= f.text_field :q, value: @query, placeholder: "Search topics, keywords...", class: "flex-1 rounded-md border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 py-2 px-3 text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 dark:placeholder:text-zinc-600 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1 dark:focus:ring-offset-zinc-900", required: true %>
      <%= f.submit "Search", class: "inline-flex items-center rounded-md bg-zinc-900 px-5 py-2 text-sm font-medium text-white shadow-sm hover:bg-zinc-800 cursor-pointer" %>
    </div>

    <div class="flex flex-wrap items-end gap-4">
      <div>
        <label class="block text-xs text-zinc-500 dark:text-zinc-400 mb-1">Published</label>
        <%= f.select :days, [["Any time", ""], ["Last 7 days", "7"], ["Last 14 days", "14"], ["Last 30 days", "30"], ["Last 60 days", "60"], ["Last 90 days", "90"]], { selected: params[:days] }, class: "rounded-md border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 py-1.5 pl-2 pr-8 text-sm text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1 dark:focus:ring-offset-zinc-900" %>
      </div>
      <div>
        <label class="block text-xs text-zinc-500 dark:text-zinc-400 mb-1">Sort by</label>
        <%= f.select :sort, [["Outlier Score", "outlier_score"], ["Views", "view_count"], ["Newest", "published_at"]], { selected: params[:sort] || "outlier_score" }, class: "rounded-md border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 py-1.5 pl-2 pr-8 text-sm text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1 dark:focus:ring-offset-zinc-900" %>
      </div>
    </div>
  <% end %>
</div>

<% if @error.present? %>
  <div class="mb-6 flex items-center gap-2 rounded-lg border border-red-200 dark:border-red-800 bg-red-50 dark:bg-red-950 px-4 py-3">
    <p class="text-sm text-red-800 dark:text-red-200"><%= @error %></p>
  </div>
<% end %>

<% if @query.present? && @videos.present? %>
  <p class="text-xs text-zinc-400 dark:text-zinc-500 mb-4"><%= @videos.size %> results</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    <% @videos.each do |video| %>
      <%= render "shared/video_card", video: video %>
    <% end %>
  </div>
<% elsif @query.present? && @videos&.empty? %>
  <div class="flex flex-col items-center justify-center rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 py-16">
    <p class="text-sm text-zinc-500 dark:text-zinc-400">No results found for "<%= @query %>"</p>
  </div>
<% end %>
