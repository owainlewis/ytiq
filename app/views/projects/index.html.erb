<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">Projects</h1>
    <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">Your video ideas and works in progress</p>
  </div>
  <%= link_to new_project_path, class: "inline-flex items-center gap-1.5 rounded-md bg-zinc-900 px-3 py-2 text-sm font-medium text-white hover:bg-zinc-800" do %>
    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
    </svg>
    New Project
  <% end %>
</div>

<% if @projects.empty? %>
  <div class="flex flex-col items-center justify-center rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 py-16">
    <svg class="h-10 w-10 text-zinc-300 dark:text-zinc-600 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
    </svg>
    <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-1">No projects yet.</p>
    <p class="text-xs text-zinc-400 dark:text-zinc-500">Create your first project to start planning a video.</p>
  </div>
<% else %>
  <div class="grid gap-4">
    <% @projects.each do |project| %>
      <% done, total = project.progress %>
      <%= link_to project_path(project), class: "block rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 hover:border-zinc-300 dark:hover:border-zinc-600 transition-colors" do %>
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-medium text-zinc-900 dark:text-zinc-100 truncate"><%= project.title %></h3>
            <div class="mt-1.5 flex items-center gap-3 text-xs text-zinc-400 dark:text-zinc-500">
              <span><%= project.inspiration_videos.count %> inspiration<%= project.inspiration_videos.count == 1 ? "" : "s" %></span>
              <span>Updated <%= time_ago_in_words(project.updated_at) %> ago</span>
            </div>
          </div>
          <div class="shrink-0 flex items-center gap-1.5">
            <div class="flex gap-0.5">
              <% Project::CHECKLIST_ITEMS.each_with_index do |item, i| %>
                <div class="h-1.5 w-3 rounded-full <%= i < done ? 'bg-emerald-500' : 'bg-zinc-200 dark:bg-zinc-700' %>"></div>
              <% end %>
            </div>
            <span class="text-[11px] text-zinc-400 dark:text-zinc-500"><%= done %>/<%= total %></span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
