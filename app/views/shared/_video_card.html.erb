<div class="group rounded-lg border border-zinc-200 bg-white overflow-hidden hover:border-zinc-300 transition-colors">
  <a href="https://www.youtube.com/watch?v=<%= video.youtube_video_id %>" target="_blank" rel="noopener" class="block">
    <% if video.thumbnail_url.present? %>
      <img src="<%= video.thumbnail_url %>" alt="<%= video.title %>" class="w-full aspect-video object-cover" loading="lazy" referrerpolicy="no-referrer">
    <% else %>
      <div class="w-full aspect-video bg-zinc-100 flex items-center justify-center">
        <span class="text-zinc-300 text-xs">No thumbnail</span>
      </div>
    <% end %>
  </a>
  <div class="p-3">
    <div class="flex items-start justify-between gap-2 mb-1.5">
      <a href="https://www.youtube.com/watch?v=<%= video.youtube_video_id %>" target="_blank" rel="noopener" class="text-sm font-medium text-zinc-900 line-clamp-2 hover:underline leading-snug"><%= video.title %></a>
      <% if video.outlier_score.present? && video.outlier_score > 0 %>
        <%
          outlier_css = case video.outlier_label
            when "viral outlier" then "bg-red-50 text-red-700 ring-1 ring-inset ring-red-200"
            when "strong outlier" then "bg-orange-50 text-orange-700 ring-1 ring-inset ring-orange-200"
            when "above average" then "bg-amber-50 text-amber-700 ring-1 ring-inset ring-amber-200"
            else "bg-zinc-50 text-zinc-500 ring-1 ring-inset ring-zinc-200"
            end
        %>
        <span class="shrink-0 inline-flex items-center rounded-full px-1.5 py-0.5 text-[11px] font-medium <%= outlier_css %>">
          <%= "%.1fx" % video.outlier_score %>
        </span>
      <% end %>
    </div>
    <% if video.channel %>
      <%= link_to video.channel.title, channel_path(video.channel), class: "text-xs text-zinc-400 hover:text-zinc-600" %>
    <% end %>
    <div class="mt-1.5 flex items-center text-xs text-zinc-400 gap-3">
      <span><%= number_to_human(video.view_count || 0, precision: 2, significant: true) %> views</span>
      <span><%= video.published_at&.strftime("%b %d, %Y") %></span>
      <span class="ml-auto">
        <%= button_to "Coach", coach_video_path(video), method: :post, class: "text-zinc-400 hover:text-zinc-900 font-medium cursor-pointer" %>
      </span>
    </div>
  </div>
</div>
