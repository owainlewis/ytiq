<%= turbo_stream_from "coach_analysis_#{@analysis.id}" %>

<div class="mb-8">
  <div class="flex items-start justify-between mb-2">
    <div>
      <h1 class="text-xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
        AI Coach: <%= @analysis.analysis_type.humanize %>
      </h1>
      <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
        <% if @analysis.analyzable.is_a?(Channel) %>
          Channel: <%= @analysis.analyzable.title %>
        <% elsif @analysis.analyzable.is_a?(Project) %>
          Project: "<%= @analysis.analyzable.title %>"
        <% else %>
          Video: "<%= @analysis.analyzable.title %>" &middot; <%= @analysis.analyzable.channel.title %>
        <% end %>
      </p>
    </div>
    <%= link_to "Back to History", coach_analyses_path, class: "text-xs font-medium text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100" %>
  </div>

  <div id="coach_status" class="mb-6">
    <%= render "coach_analyses/status", analysis: @analysis %>
  </div>

  <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-6">
    <div id="coach_response">
      <%= render "coach_analyses/response", analysis: @analysis %>
    </div>
  </div>
</div>
