<!DOCTYPE html>
<html class="h-full bg-zinc-50">
  <head>
    <title><%= content_for(:title) || "YTIQ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <% if user_signed_in? %>
      <div class="flex h-screen overflow-hidden">
        <%# ── Left Sidebar ── %>
        <aside class="hidden md:flex md:flex-col md:w-60 border-r border-zinc-200 bg-white">
          <%# Logo %>
          <div class="flex h-14 items-center px-5 border-b border-zinc-200">
            <%= link_to dashboard_path, class: "flex items-center gap-2" do %>
              <span class="text-base font-bold tracking-tight text-zinc-900">YTIQ</span>
            <% end %>
          </div>

          <%# Navigation %>
          <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
            <%= link_to dashboard_path, class: "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium #{request.path == dashboard_path ? 'bg-zinc-100 text-zinc-900' : 'text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900'}" do %>
              <svg class="h-4 w-4 shrink-0 <%= request.path == dashboard_path ? 'text-zinc-900' : 'text-zinc-400 group-hover:text-zinc-600' %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
              Dashboard
            <% end %>

            <%= link_to channels_path, class: "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium #{request.path.start_with?('/channels') ? 'bg-zinc-100 text-zinc-900' : 'text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900'}" do %>
              <svg class="h-4 w-4 shrink-0 <%= request.path.start_with?('/channels') ? 'text-zinc-900' : 'text-zinc-400 group-hover:text-zinc-600' %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5-3.9 19.5m-2.1-19.5-3.9 19.5" />
              </svg>
              Channels
            <% end %>

            <%= link_to search_path, class: "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium #{request.path == search_path ? 'bg-zinc-100 text-zinc-900' : 'text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900'}" do %>
              <svg class="h-4 w-4 shrink-0 <%= request.path == search_path ? 'text-zinc-900' : 'text-zinc-400 group-hover:text-zinc-600' %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              Search
            <% end %>

            <%= link_to videos_path, class: "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium #{request.path == videos_path ? 'bg-zinc-100 text-zinc-900' : 'text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900'}" do %>
              <svg class="h-4 w-4 shrink-0 <%= request.path == videos_path ? 'text-zinc-900' : 'text-zinc-400 group-hover:text-zinc-600' %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
              </svg>
              Videos
            <% end %>

            <%= link_to projects_path, class: "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium #{request.path.start_with?('/projects') ? 'bg-zinc-100 text-zinc-900' : 'text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900'}" do %>
              <svg class="h-4 w-4 shrink-0 <%= request.path.start_with?('/projects') ? 'text-zinc-900' : 'text-zinc-400 group-hover:text-zinc-600' %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z" />
              </svg>
              Projects
            <% end %>

            <%= link_to coach_analyses_path, class: "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium #{request.path.start_with?('/coach') ? 'bg-zinc-100 text-zinc-900' : 'text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900'}" do %>
              <svg class="h-4 w-4 shrink-0 <%= request.path.start_with?('/coach') ? 'text-zinc-900' : 'text-zinc-400 group-hover:text-zinc-600' %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
              </svg>
              AI Coach
            <% end %>

            <div class="pt-4 mt-4 border-t border-zinc-200">
              <%= link_to settings_path, class: "group flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium #{request.path == settings_path ? 'bg-zinc-100 text-zinc-900' : 'text-zinc-600 hover:bg-zinc-50 hover:text-zinc-900'}" do %>
                <svg class="h-4 w-4 shrink-0 <%= request.path == settings_path ? 'text-zinc-900' : 'text-zinc-400 group-hover:text-zinc-600' %>" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                </svg>
                Settings
              <% end %>
            </div>
          </nav>

          <%# User ── bottom %>
          <div class="border-t border-zinc-200 px-3 py-3">
            <div class="flex items-center gap-3 rounded-md px-3 py-2">
              <% if current_user.avatar_url.present? %>
                <img src="<%= current_user.avatar_url %>" class="h-7 w-7 rounded-full" alt="" referrerpolicy="no-referrer">
              <% else %>
                <div class="h-7 w-7 rounded-full bg-zinc-200 flex items-center justify-center">
                  <span class="text-xs font-medium text-zinc-600"><%= (current_user.name || current_user.email).first.upcase %></span>
                </div>
              <% end %>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-zinc-900 truncate"><%= current_user.name || current_user.email %></p>
              </div>
              <%= button_to destroy_user_session_path, method: :delete, class: "text-zinc-400 hover:text-zinc-600" do %>
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                </svg>
              <% end %>
            </div>
          </div>
        </aside>

        <%# ── Main Content ── %>
        <div class="flex flex-1 flex-col overflow-hidden">
          <%# Mobile header %>
          <header class="md:hidden flex h-14 items-center gap-4 border-b border-zinc-200 bg-white px-4">
            <span class="text-base font-bold tracking-tight text-zinc-900">YTIQ</span>
            <nav class="ml-auto flex items-center gap-2 text-sm">
              <%= link_to "Dashboard", dashboard_path, class: "text-zinc-600 hover:text-zinc-900" %>
              <%= link_to "Channels", channels_path, class: "text-zinc-600 hover:text-zinc-900" %>
              <%= link_to "Projects", projects_path, class: "text-zinc-600 hover:text-zinc-900" %>
              <%= link_to "Coach", coach_analyses_path, class: "text-zinc-600 hover:text-zinc-900" %>
            </nav>
          </header>

          <main class="flex-1 overflow-y-auto">
            <div class="mx-auto max-w-6xl px-6 py-8">
              <div id="flash">
              <% if notice.present? %>
                <div class="mb-6 flex items-center gap-2 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3">
                  <svg class="h-4 w-4 text-emerald-600 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                  </svg>
                  <p class="text-sm text-emerald-800"><%= notice %></p>
                </div>
              <% end %>
              <% if alert.present? %>
                <div class="mb-6 flex items-center gap-2 rounded-lg border border-red-200 bg-red-50 px-4 py-3">
                  <svg class="h-4 w-4 text-red-600 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
                  </svg>
                  <p class="text-sm text-red-800"><%= alert %></p>
                </div>
              <% end %>
              </div>
              <%= yield %>
            </div>
          </main>
        </div>
      </div>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
