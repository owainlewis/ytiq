<div class="min-h-screen bg-zinc-950 flex flex-col justify-center items-center">
  <div class="text-center">
    <h1 class="text-5xl font-bold tracking-tight text-white mb-3">YTIQ</h1>
    <p class="text-lg text-zinc-400 mb-10 max-w-md">Find outlier YouTube videos and track channels. Discover what's working before everyone else does.</p>
    <div class="flex items-center justify-center gap-3">
      <%= link_to "Get Started", new_user_registration_path, class: "inline-flex items-center rounded-md bg-white px-5 py-2.5 text-sm font-medium text-zinc-900 shadow-sm hover:bg-zinc-100" %>
      <%= link_to "Sign In", new_user_session_path, class: "inline-flex items-center rounded-md border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 hover:bg-zinc-800 hover:text-white" %>
    </div>
  </div>
  <div class="mt-20 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-3xl px-4">
    <div class="text-center">
      <div class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-zinc-800 mb-3">
        <svg class="h-5 w-5 text-zinc-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
        </svg>
      </div>
      <h3 class="text-white font-medium text-sm mb-1">Outlier Detection</h3>
      <p class="text-zinc-500 text-xs leading-relaxed">Find videos that dramatically outperform a channel's average.</p>
    </div>
    <div class="text-center">
      <div class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-zinc-800 mb-3">
        <svg class="h-5 w-5 text-zinc-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h15m-16.5 7.5h15m-1.8-13.5-3.9 19.5m-2.1-19.5-3.9 19.5" />
        </svg>
      </div>
      <h3 class="text-white font-medium text-sm mb-1">Channel Tracking</h3>
      <p class="text-zinc-500 text-xs leading-relaxed">Follow channels and get automatic updates every 6 hours.</p>
    </div>
    <div class="text-center">
      <div class="inline-flex items-center justify-center h-10 w-10 rounded-lg bg-zinc-800 mb-3">
        <svg class="h-5 w-5 text-zinc-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
      </div>
      <h3 class="text-white font-medium text-sm mb-1">Topic Research</h3>
      <p class="text-zinc-500 text-xs leading-relaxed">Search any topic and see which videos are over-performing.</p>
    </div>
  </div>
</div>
