<div class="min-h-screen bg-zinc-950 flex flex-col justify-center items-center px-4">
  <div class="w-full max-w-sm">
    <h1 class="text-2xl font-bold tracking-tight text-white text-center mb-8">Sign in to YTIQ</h1>
    <div class="rounded-lg border border-zinc-200 bg-white p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: "space-y-4") do |f| %>
        <div>
          <label class="block text-xs font-medium text-zinc-700 mb-1.5">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-md border border-zinc-200 py-2 px-3 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-zinc-700 mb-1.5">Password</label>
          <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-md border border-zinc-200 py-2 px-3 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1" %>
        </div>
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "h-3.5 w-3.5 rounded border-zinc-300 text-zinc-900 focus:ring-zinc-900" %>
            <label class="ml-2 text-xs text-zinc-500">Remember me</label>
          </div>
        <% end %>
        <%= f.submit "Sign In", class: "w-full rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-zinc-800 cursor-pointer" %>
      <% end %>

      <div class="mt-5">
        <div class="relative">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-zinc-200"></div></div>
          <div class="relative flex justify-center text-xs"><span class="bg-white px-2 text-zinc-400">Or</span></div>
        </div>
        <div class="mt-4">
          <%= button_to "Sign in with Google", user_google_oauth2_omniauth_authorize_path, class: "w-full rounded-md border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-700 shadow-sm hover:bg-zinc-50 cursor-pointer", data: { turbo: false } %>
        </div>
      </div>

      <p class="mt-4 text-center text-xs text-zinc-400">
        Don't have an account? <%= link_to "Sign up", new_user_registration_path, class: "text-zinc-900 font-medium hover:underline" %>
      </p>
    </div>
  </div>
</div>
