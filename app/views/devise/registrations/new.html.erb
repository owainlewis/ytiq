<div class="min-h-screen bg-zinc-950 flex flex-col justify-center items-center px-4">
  <div class="w-full max-w-sm">
    <h1 class="text-2xl font-bold tracking-tight text-white text-center mb-8">Create your YTIQ account</h1>
    <div class="rounded-lg border border-zinc-200 bg-white p-6">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-4") do |f| %>
        <% if resource.errors.any? %>
          <div class="rounded-lg border border-red-200 bg-red-50 p-3">
            <% resource.errors.full_messages.each do |msg| %>
              <p class="text-xs text-red-700"><%= msg %></p>
            <% end %>
          </div>
        <% end %>
        <div>
          <label class="block text-xs font-medium text-zinc-700 mb-1.5">Name</label>
          <%= f.text_field :name, autocomplete: "name", class: "w-full rounded-md border border-zinc-200 py-2 px-3 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-zinc-700 mb-1.5">Email</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-md border border-zinc-200 py-2 px-3 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-zinc-700 mb-1.5">Password</label>
          <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-md border border-zinc-200 py-2 px-3 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1" %>
        </div>
        <div>
          <label class="block text-xs font-medium text-zinc-700 mb-1.5">Confirm Password</label>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-md border border-zinc-200 py-2 px-3 text-sm text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-1" %>
        </div>
        <%= f.submit "Create Account", class: "w-full rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-zinc-800 cursor-pointer" %>
      <% end %>

      <div class="mt-5">
        <div class="relative">
          <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-zinc-200"></div></div>
          <div class="relative flex justify-center text-xs"><span class="bg-white px-2 text-zinc-400">Or</span></div>
        </div>
        <div class="mt-4">
          <%= button_to "Sign up with Google", user_google_oauth2_omniauth_authorize_path, class: "w-full rounded-md border border-zinc-200 bg-white px-4 py-2 text-sm font-medium text-zinc-700 shadow-sm hover:bg-zinc-50 cursor-pointer", data: { turbo: false } %>
        </div>
      </div>

      <p class="mt-4 text-center text-xs text-zinc-400">
        Already have an account? <%= link_to "Sign in", new_user_session_path, class: "text-zinc-900 font-medium hover:underline" %>
      </p>
    </div>
  </div>
</div>
