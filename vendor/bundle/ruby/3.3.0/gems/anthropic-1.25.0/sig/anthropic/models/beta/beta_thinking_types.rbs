        attr_accessor enabled: Anthropic::Beta::BetaCapabilitySupport

        def initialize: (
          adaptive: Anthropic::Beta::BetaCapabilitySupport,
          enabled: Anthropic::Beta::BetaCapabilitySupport
        ) -> void

        def to_hash: -> {
          adaptive: Anthropic::Beta::BetaCapabilitySupport,
          enabled: Anthropic::Beta::BetaCapabilitySupport
        }
