module Anthropic
  module Models
    type thinking_config_enabled =
      {
        budget_tokens: Integer,
        type: :enabled,
        display_: Anthropic::Models::ThinkingConfigEnabled::display_?
      }

    class ThinkingConfigEnabled < Anthropic::Internal::Type::BaseModel
      attr_accessor budget_tokens: Integer

      attr_accessor type: :enabled

      attr_accessor display_: Anthropic::Models::ThinkingConfigEnabled::display_?

      def initialize: (
        budget_tokens: Integer,
        ?display_: Anthropic::Models::ThinkingConfigEnabled::display_?,
        ?type: :enabled
      ) -> void

      def to_hash: -> {
        budget_tokens: Integer,
        type: :enabled,
        display_: Anthropic::Models::ThinkingConfigEnabled::display_?
      }

      type display_ = :summarized | :omitted

      module Display
        extend Anthropic::Internal::Type::Enum

        SUMMARIZED: :summarized
        OMITTED: :omitted

        def self?.values: -> ::Array[Anthropic::Models::ThinkingConfigEnabled::display_]
      end
    end
  end
end
